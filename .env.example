# Backend (server) — required for chat to work
GEMINI_API_KEY=your_gemini_api_key
MONGODB_URI=your_mongodb_connection_string

# Optional: YouTube Channel Download (uses sample data when missing)
YOUTUBE_API_KEY=your_youtube_data_api_key

# Frontend — only needed for production deploy (REACT_APP_API_URL)
# For local dev, the proxy handles /api → localhost:3001
# REACT_APP_API_URL=https://your-backend.onrender.com
